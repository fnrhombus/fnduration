{
  "name": "fnduration",
  "version": "0.1.0",
  "description": "Bidirectional human-readable duration parsing and formatting. Parse '3 hours 20 minutes' to ms and back.",
  "keywords": [
    "duration",
    "parse-duration",
    "format-duration",
    "human-readable",
    "time",
    "ms",
    "milliseconds",
    "interval",
    "pretty-ms"
  ],
  "license": "MIT",
  "author": "fnrhombus",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnrhombus/fnduration"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
